# ── Core ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────────────────────
# Comma-separated API keys (rotate regularly)
API_KEYS=your-key-1,your-key-2

# ── Market Data ───────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=          # https://www.alphavantage.co/support/#api-key
# Binance requires no key for public endpoints

# ── Database (optional) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/decision_engine

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info
